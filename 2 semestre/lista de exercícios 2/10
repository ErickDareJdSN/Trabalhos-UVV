import random

def gerar_e_encontrar_vencedor(num_maratonistas):
    menor_tempo = float('inf')  # Inicializa com infinito
    inscricao_vencedor = None   # Armazena a inscrição do vencedor
    
    # Gera inscrições únicas
    inscricoes = random.sample(range(1, 20001), num_maratonistas)
    
    # Gera tempos e verifica o menor tempo
    for inscricao in inscricoes:
        tempo = random.uniform(120, 360)  # Tempo entre 120 e 360 minutos
        if tempo < menor_tempo:
            menor_tempo = tempo
            inscricao_vencedor = inscricao
    
    return inscricao_vencedor, menor_tempo

def main():
    num_maratonistas = 20000
    print(f"Gerando dados para {num_maratonistas} maratonistas...")
    
    # Encontra o vencedor diretamente
    inscricao_vencedor, menor_tempo = gerar_e_encontrar_vencedor(num_maratonistas)
    
    # Exibe o resultado
    if inscricao_vencedor is not None:
        print(f"\nVencedor: Inscrição {inscricao_vencedor}, Tempo: {menor_tempo:.2f} minutos")
    else:
        print("\nNenhum maratonista foi registrado.")

if __name__ == "__main__":
    main()