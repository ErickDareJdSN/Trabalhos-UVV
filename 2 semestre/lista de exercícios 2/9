import math

def calcular_media_intervalo():
    # Definindo os limites do intervalo
    limite_inferior = 10 * math.pi ** 3
    limite_superior = 100 * math.pi
    
    # Lista para armazenar números válidos
    numeros = []
    
    while True:
        try:
            # Lendo o número do usuário
            num = float(input("Digite um número (ou um número fora do intervalo para parar): "))
            
            # Verificando se o número está fora do intervalo
            if num < limite_inferior or num > limite_superior:
                break
            
            # Adicionando número válido à lista
            numeros.append(num)
            
        except ValueError:
            print("Erro: Por favor, insira um número válido.")
    
    # Calculando a média, se houver números válidos
    if numeros:
        media = sum(numeros) / len(numeros)
        print(f"Números lidos no intervalo [{limite_inferior:.2f}, {limite_superior:.2f}]: {numeros}")
        print(f"Média dos números: {media:.2f}")
    else:
        print("Nenhum número válido foi digitado no intervalo.")

def main():
    print(f"Intervalo: [10 * π³, 100 * π] = [{10 * math.pi ** 3:.2f}, {100 * math.pi:.2f}]")
    calcular_media_intervalo()

if __name__ == "__main__":
    main()