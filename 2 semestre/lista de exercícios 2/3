# Inicializando as listas para armazenar números pares e ímpares
pares = []
impares = []

# Separando números pares e ímpares no intervalo [10, 90]
for i in range(10, 91):  # Inclui 90 no intervalo
    if i % 2 == 0:
        pares.append(i)
    else:
        impares.append(i)

# Calculando as somas
soma_pares = sum(pares)
soma_impares = sum(impares)

# Exibindo os resultados
print("Soma dos números pares:", soma_pares)
print("Soma dos números ímpares:", soma_impares)